---
import ThemeToggle from "./ThemeToggle.tsx";

const navLinks = [
  { href: "/",        label: "Home" },
  { href: "/projects",label: "Projects" },
  { href: "/about",   label: "About" },
  { href: "/resume",  label: "Résumé", external: false, accent: true },
];

const currentPath = Astro.url.pathname;
---

<header class="glass" style="
  position: sticky;
  top: 0;
  z-index: 50;
  width: 100%;
  border-bottom: 1px solid var(--border);
">
  <div style="
    max-width: 72rem;
    margin: 0 auto;
    height: 3.75rem;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  ">

    <!-- Wordmark -->
    <a href="/" aria-label="Home" class="wordmark">
      Jingzhi<span style="color:var(--coral);">.</span>
    </a>

    <!-- Desktop nav + toggle -->
    <div style="display:flex;align-items:center;gap:0.5rem;">
      <nav aria-label="Main navigation" class="main-nav">
        {navLinks.map(({ href, label, accent }) => {
          const isActive =
            href === "/" ? currentPath === "/" : currentPath.startsWith(href);
          return (
            <a
              href={href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "nav-link",
                isActive ? "nav-link--active" : "",
                accent  ? "nav-link--accent"  : "",
              ]}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Mobile: hamburger placeholder (simple links shown inline) -->
      <nav aria-label="Mobile navigation" class="mobile-nav">
        {navLinks.map(({ href, label, accent }) => {
          const isActive =
            href === "/" ? currentPath === "/" : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                "mobile-link",
                isActive  ? "mobile-link--active" : "",
                accent    ? "nav-link--accent"    : "",
              ]}
            >
              {label[0]}
            </a>
          );
        })}
      </nav>

      <ThemeToggle client:load />
    </div>
  </div>
</header>

<style>
  /* ── Wordmark ───────────────────────────────────────────────── */
  .wordmark {
    font-family: "Instrument Serif", Georgia, serif;
    font-style: italic;
    font-size: 1.35rem;
    letter-spacing: -0.02em;
    color: var(--text);
    text-decoration: none;
    transition: opacity 0.18s;
    flex-shrink: 0;
  }
  .wordmark:hover { opacity: 0.65; }

  /* ── Desktop nav ────────────────────────────────────────────── */
  .main-nav {
    display: none;
    align-items: center;
    gap: 0.125rem;
  }

  @media (min-width: 540px) {
    .main-nav   { display: flex; }
    .mobile-nav { display: none !important; }
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-size: 0.825rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text-2);
    text-decoration: none;
    background: transparent;
    border: 1px solid transparent;
    transition: color 0.18s, background 0.18s, border-color 0.18s;
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--coral-dim);
  }

  .nav-link--active {
    color: var(--coral);
    background: var(--coral-dim);
  }

  /* Résumé gets a subtle outlined treatment */
  .nav-link--accent {
    color: var(--coral);
    border-color: var(--coral-mid);
    font-weight: 600;
  }
  .nav-link--accent:hover {
    background: var(--coral-mid);
    color: var(--coral);
    border-color: var(--coral);
  }

  /* ── Mobile nav (icon initials) ─────────────────────────────── */
  .mobile-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .mobile-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-2);
    text-decoration: none;
    background: transparent;
    transition: color 0.18s, background 0.18s;
  }

  .mobile-link:hover      { color: var(--text); background: var(--coral-dim); }
  .mobile-link--active    { color: var(--coral); background: var(--coral-dim); }
</style>
