---
/**
 * Impact — Post-launch metrics grid.
 * Shows quantified outcomes: before/after numbers, uplift %, ratings, etc.
 */

interface Metric {
  value: string;
  label: string;
  delta?: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
if (!metrics || metrics.length === 0) return;
---

<section style="margin-bottom:3.5rem;">
  <!-- Heading -->
  <div style="display:flex;align-items:center;gap:0.625rem;margin-bottom:1.5rem;">
    <div style="width:2px;height:1.25rem;border-radius:9999px;background:var(--coral);"></div>
    <h2 style="
      font-family: 'Instrument Serif', Georgia, serif;
      font-style: italic;
      font-size: 1.65rem;
      font-weight: 400;
      letter-spacing: -0.025em;
      color: var(--text);
      margin: 0;
    ">Impact</h2>
  </div>

  <!-- Metrics grid -->
  <div style="
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 10rem), 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 1.5rem;
    overflow: hidden;
  ">
    {metrics.map((metric, i) => (
      <div style={`
        background: var(--card);
        padding: 1.5rem;
        position: relative;
        ${i === 0 ? "background: var(--bg-alt);" : ""}
      `}>
        <!-- Value -->
        <p style="
          font-family: 'Instrument Serif', Georgia, serif;
          font-style: italic;
          font-size: clamp(2rem, 5vw, 2.75rem);
          font-weight: 400;
          line-height: 1;
          color: var(--coral);
          margin-bottom: 0.35rem;
          letter-spacing: -0.02em;
        ">{metric.value}</p>

        <!-- Label -->
        <p style="
          font-size: 0.8rem;
          font-weight: 600;
          color: var(--text-2);
          line-height: 1.35;
          margin-bottom: 0.25rem;
        ">{metric.label}</p>

        <!-- Delta / context -->
        {metric.delta && (
          <p style="
            font-size: 0.72rem;
            font-weight: 300;
            color: var(--text-3);
            font-style: italic;
          ">{metric.delta}</p>
        )}
      </div>
    ))}
  </div>
</section>
