---
/**
 * PhoneGallery — horizontal scrollable strip of phone mockups.
 *
 * Pass an array of items with `src` (image path in src/assets/images/)
 * and `label`. Each renders inside a clean phone frame.
 *
 * Usage in MDX:
 *   <PhoneGallery items={[
 *     { src: "/images/onboarding/ob-01-welcome.png", label: "Welcome" },
 *     { src: "/images/onboarding/ob-02-social-proof.png", label: "Social Proof" },
 *     ...
 *   ]} />
 */
import { getImage } from "astro:assets";
import { resolveImage } from "../../utils/images";

interface PhoneItem {
  src: string;
  label: string;
  alt?: string;
}

interface Props {
  items: PhoneItem[];
}

const { items } = Astro.props;

const resolvedItems = await Promise.all(
  items.map(async (item) => {
    const imgData = await resolveImage(item.src);
    const optimized = imgData
      ? (await getImage({ src: imgData, width: 390, format: "webp", quality: 90 })).src
      : undefined;
    return { ...item, optimizedSrc: optimized };
  })
);
---

<div class="pg-section">
  <div class="pg-scroll">
    {resolvedItems.map((item, i) => (
      <div class="pg-wrap">
        {item.optimizedSrc ? (
          <img
            src={item.optimizedSrc}
            alt={item.alt ?? item.label}
            class="pg-screen"
          />
        ) : (
          <div class="pg-placeholder">
            <span>{item.label}</span>
          </div>
        )}
        <p class="pg-label">
          <span class="pg-num">{String(i + 1).padStart(2, "0")}</span>
          {item.label}
        </p>
      </div>
    ))}
  </div>
</div>

<style>
  .pg-section {
    margin: 1.5rem 0 2rem;
  }

  .pg-scroll {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding: 0.75rem 0.25rem 1rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .pg-scroll::-webkit-scrollbar { display: none; }

  .pg-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .pg-screen {
    height: 320px;
    width: auto;
    display: block;
    border-radius: 8px;
  }

  .pg-placeholder {
    width: 160px;
    aspect-ratio: 9/19.5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #aaa;
    font-size: 0.55rem;
    font-family: system-ui, sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1.5px dashed #ddd;
    border-radius: 8px;
  }

  .pg-label {
    font-size: 0.65rem;
    color: var(--text-3, #999);
    font-family: 'Manrope', system-ui, sans-serif;
    text-align: center;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .pg-num {
    font-weight: 700;
    color: var(--coral, #EF4623);
    font-size: 0.6rem;
    letter-spacing: 0.04em;
  }
</style>
