---
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import AnimatedHero from "../components/AnimatedHero.tsx";
import ProjectCard from "../components/ProjectCard.tsx";
import { resolveImage } from "../utils/images";

// ── Profile photo ──────────────────────────────────────────────────────────
// Put your photo in src/assets/images/ and update the path below.
// Leave as undefined to keep the placeholder.
const profilePhotoSrc = "/images/jingzhi.png";
const profilePhotoBackSrc = "/images/jingzhi-back.png"; // ← upload your back image here

const profileImageData = await resolveImage(profilePhotoSrc);
const profilePhoto = profileImageData
  ? (await getImage({ src: profileImageData, width: 640, format: "webp", quality: 90 })).src
  : undefined;

const profileBackData = await resolveImage(profilePhotoBackSrc);
const profilePhotoBack = profileBackData
  ? (await getImage({ src: profileBackData, width: 640, format: "webp", quality: 90 })).src
  : undefined;

const allProjects = await getCollection("projects", ({ data }) => !data.draft);
const featuredRaw = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Pre-optimise cover images so ProjectCard (React) gets a usable URL
const featured = await Promise.all(
  featuredRaw.map(async (p) => {
    const imgData = await resolveImage(p.data.cover);
    const coverSrc = imgData
      ? (await getImage({ src: imgData, width: 1800, format: "webp", quality: 90 })).src
      : p.data.cover; // fall back to original path (e.g. public/ SVGs)
    return { ...p, coverSrc };
  })
);

// ── Building ──────────────────────────────────────────────────────────────
const buildingRaw = [
  {
    title: "Design System Documentation Helper",
    description: "A Figma plugin that selects a component on your canvas and automatically generates a full, structured documentation frame.",
    tags: ["Javascript", "TypeScript"],
    link: "https://github.com/jingzhix255/Design-System-Documentation-Helper.git",
    src: "",        // static image fallback
    video:"/images/plug-in.mp4",      // mp4/webm path, e.g. "/videos/demo.mp4"
  },
];

const building = await Promise.all(
  buildingRaw.map(async (b) => {
    const imgData = await resolveImage(b.src);
    const thumbSrc = imgData
      ? (await getImage({ src: imgData, width: 1200, format: "webp", quality: 90 })).src
      : undefined;
    return { ...b, thumbSrc };
  })
);

const collabRaw = [
  {
    title: "Improving Design Impact and Maturity",
    company: "Eightpoint",
    description: "Dedicated to showcasing the impact of design and persistently advocating for its integration into collaboration.",
    period: "2023-2025",
    src: "/images/collaA.png",
  },
  {
    title: "Enhancing Design & Development Collaboration Process",
    company: "Eightpoint",
    description: "Continually find ways to improve design working model and process standardization.",
    period: "2023-2025",
    src: "/images/collaB.png",
  },
];

const collaborations = await Promise.all(
  collabRaw.map(async (c) => {
    const imgData = await resolveImage(c.src);
    const thumbSrc = imgData
      ? (await getImage({ src: imgData, width: 1200, format: "webp", quality: 90 })).src
      : undefined;
    return { ...c, thumbSrc };
  })
);
---

<BaseLayout
  title="Jingzhi Xu — Product Designer"
  description="Product designer crafting thoughtful digital experiences — from research to high-fidelity."
>
  <!-- Hero -->
  <AnimatedHero
    client:load
    name="Hey, I am Jingzhi"
    role="Product Designer + Builder"
    bio={`I am a growth product designer with 5+ YOE in Acquisition, Monetization, User Retention, and Design System. Currently building spam blocking solutions <a href="https://hiya.com" target="_blank" rel="noopener noreferrer" style="color:var(--coral);text-decoration:none;font-weight:500;border-bottom:1px solid var(--coral-mid);transition:border-color 0.2s;">@Hiya</a>.`}
    photo={profilePhoto}
    photoBack={profilePhotoBack}
  />

  <!-- ── Selected work ─────────────────────────────────────────── -->
  <section class="page-section">
    <div class="section-header">
      <h2 class="section-title">Selected work</h2>
      <a href="/projects" class="section-link">All projects →</a>
    </div>

    <div class="projects-grid">
      {
        featured.map((project, i) => (
          <ProjectCard
            client:visible
            title={project.data.title}
            description={project.data.description}
            tags={project.data.tags}
            slug={project.slug}
            featured={project.data.featured}
            cover={project.coverSrc}
            url={project.data.url}
            repo={project.data.repo}
            index={i}
          />
        ))
      }
    </div>
  </section>

  <!-- ── Building ──────────────────────────────────────────────── -->
  <section class="page-section" style="border-top:1px solid var(--border);">
    <div class="section-header">
      <h2 class="section-title">Building</h2>
    </div>

    <div class="build-list">
      {building.map((item, i) => (
        <article class="build-row build-card" style={`animation-delay:${i * 100}ms`}>
          <!-- Left: info -->
          <div class="build-info">
            <div class="build-tags" style="margin-bottom:1rem;">
              {item.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <h3 class="build-title">{item.title}</h3>
            <p class="build-desc">{item.description}</p>
            {item.link && (
              <a href={item.link} target="_blank" rel="noopener noreferrer" class="build-link">
                More Information →
              </a>
            )}
          </div>

          <!-- Right: video or image -->
          <div class="build-media">
            {item.video ? (
              <video
                src={item.video}
                autoplay loop muted playsinline
                class="build-media-fill"
                aria-label={item.title}
              />
            ) : item.thumbSrc ? (
              <img src={item.thumbSrc} alt={item.title} class="build-media-fill build-thumb-img" />
            ) : (
              <div class="build-thumb-placeholder">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="16 18 22 12 16 6" />
                  <polyline points="8 6 2 12 8 18" />
                </svg>
                <span>Add video or image</span>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ── Collaboration ─────────────────────────────────────────── -->
  <section class="page-section" style="border-top:1px solid var(--border);">
    <div class="section-header">
      <h2 class="section-title">Collaboration</h2>
    </div>

    <div class="projects-grid">
      {collaborations.map((collab, i) => (
        <article class="collab-card" style={`animation-delay:${i * 90}ms`}>
          <!-- Thumbnail -->
          <div class="collab-thumb">
            {collab.thumbSrc ? (
              <img src={collab.thumbSrc} alt={collab.title} class="collab-thumb-img" />
            ) : (
              <div class="collab-thumb-inner">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.5"
                  stroke-linecap="round" stroke-linejoin="round"
                  aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="3" />
                  <circle cx="8.5" cy="8.5" r="1.5" />
                  <polyline points="21 15 16 10 5 21" />
                </svg>
                <span class="collab-thumb-label">Add image</span>
              </div>
            )}
          </div>

          <!-- Body -->
          <div class="collab-body">
            <div class="collab-meta">
              <span class="collab-company">{collab.company}</span>
              <span class="collab-period">{collab.period}</span>
            </div>
            <h3 class="collab-title">{collab.title}</h3>
            <p class="collab-desc">{collab.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  // Section headers
  document.querySelectorAll(".section-header").forEach((el) => observer.observe(el));

  // Cards — stagger delay per index within their grid
  document.querySelectorAll(".collab-card, .build-card").forEach((el, i) => {
    (el as HTMLElement).style.animationDelay = `${i * 80}ms`;
    observer.observe(el);
  });
</script>

<style>
  /* ── Scroll-reveal keyframes ─────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Section headers fade up on scroll */
  .section-header {
    opacity: 0;
    animation: fadeUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .section-header.visible { opacity: 1; }

  /* Cards stagger in */
  .collab-card,
  .build-card {
    opacity: 0;
    transform: translateY(24px);
    animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-play-state: paused;
  }
  .collab-card.visible,
  .build-card.visible {
    animation-play-state: running;
  }

  /* ── Shared layout ───────────────────────────────────────────── */
  .page-section {
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }

  /* "Selected work" + "Collaboration" both use a full-bleed divider at top */
  section.page-section + section.page-section {
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .section-title {
    font-family: "Instrument Serif", Georgia, serif;
    font-style: italic;
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.1;
    margin: 0;
  }

  .section-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--coral);
    text-decoration: none;
    transition: opacity 0.18s, transform 0.22s cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-block;
  }
  .section-link:hover {
    opacity: 0.8;
    transform: translateX(4px);
  }

  /* ── 2×2 project grid ───────────────────────────────────────── */
  .projects-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 640px) {
    .projects-grid { grid-template-columns: 1fr; }
  }

  /* ── Collaboration cards ────────────────────────────────────── */
  .collab-card {
    display: flex;
    flex-direction: column;
    border-radius: 1.75rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card);
    transition: box-shadow 0.35s, border-color 0.35s, transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .collab-card:hover {
    box-shadow: 0 20px 48px rgba(239, 70, 35, 0.12);
    border-color: var(--coral-mid);
    transform: translateY(-4px);
  }

  /* Thumbnail placeholder */
  .collab-thumb {
    position: relative;
    background: var(--card);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }

  .collab-thumb-img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .collab-card:hover .collab-thumb-img {
    transform: scale(1.04);
  }

  .collab-thumb-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--coral);
    opacity: 0.35;
    border: 1.5px dashed var(--coral-mid);
    border-radius: 0; /* card overflow clips it */
    margin: 1rem;
    border-radius: 1rem;
  }

  .collab-thumb-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Card body */
  .collab-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .collab-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.625rem;
    gap: 0.5rem;
  }

  .collab-company {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--coral);
  }

  .collab-period {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-3);
    background: var(--tag-bg);
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
  }

  .collab-title {
    font-family: "Instrument Serif", Georgia, serif;
    font-style: italic;
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.18;
    color: var(--text);
    margin-bottom: 0.625rem;
  }

  .collab-desc {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.65;
    color: var(--text-2);
    flex: 1;
    margin-bottom: 1.125rem;
  }

  .collab-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--tag-text);
    background: var(--tag-bg);
    padding: 0.22rem 0.6rem;
    border-radius: 9999px;
  }

  /* ── Building — left/right rows ─────────────────────────────── */
  .build-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .build-row {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 0;
    border-radius: 1.75rem;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--card);
    min-height: 340px;
    transition: box-shadow 0.35s, border-color 0.35s, transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .build-row:hover {
    box-shadow: 0 20px 48px rgba(239, 70, 35, 0.10);
    border-color: var(--coral-mid);
    transform: translateY(-4px);
  }

  @media (max-width: 700px) {
    .build-row { grid-template-columns: 1fr; }
  }

  /* Left: info panel */
  .build-info {
    padding: 2.25rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 1px solid var(--border);
  }
  @media (max-width: 700px) {
    .build-info { border-right: none; border-bottom: 1px solid var(--border); }
  }

  .build-title {
    font-family: "Instrument Serif", Georgia, serif;
    font-style: italic;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--text);
    margin: 0 0 0.75rem;
  }
  .build-desc {
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--text-2);
    margin: 0 0 1.5rem;
    flex: 1;
  }
  .build-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .build-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--coral);
    text-decoration: none;
    transition: transform 0.22s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.18s;
    margin-top: 1.5rem;
    width: fit-content;
  }
  .build-link:hover { opacity: 0.8; transform: translateX(4px); }

  /* Right: media panel */
  .build-media {
    position: relative;
    background: var(--bg-alt);
    overflow: hidden;
  }
  .build-media-fill {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .build-row:hover .build-thumb-img {
    transform: scale(1.04);
  }
  .build-thumb-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--coral);
    opacity: 0.35;
    margin: 1rem;
    border: 1.5px dashed var(--coral-mid);
    border-radius: 1rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

</style>
