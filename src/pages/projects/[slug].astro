---
import { getCollection, getEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// Case study section components
import CaseStudyHero     from "../../components/case-study/Hero.astro";
import CaseStudyMeta     from "../../components/case-study/Meta.astro";
import BigReveal         from "../../components/case-study/Reveal.astro";
import DeepDives         from "../../components/case-study/DeepDives.astro";
import ImpactGrid        from "../../components/case-study/ImpactGrid.astro";
import ReflectionBlock   from "../../components/case-study/Reflection.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;
const project = await getEntry("projects", slug!);
if (!project) return Astro.redirect("/404");

const { Content } = await project.render();
const d = project.data;
---

<BaseLayout
  title={`${d.title} — Portfolio`}
  description={d.description}
  ogImage={d.cover}
>
  <article style="max-width:52rem;margin:0 auto;padding:3.5rem 1.5rem 7rem;">

    <!-- ── Back navigation ─────────────────────────────────── -->
    <nav style="margin-bottom:2.5rem;">
      <a
        href="/projects"
        style="
          display: inline-flex;
          align-items: center;
          gap: 0.375rem;
          font-size: 0.82rem;
          font-weight: 600;
          color: var(--text-3);
          text-decoration: none;
          padding: 0.4rem 0.875rem;
          border: 1px solid var(--border);
          border-radius: 9999px;
          background: var(--card);
          transition: color 0.2s, border-color 0.2s;
        "
        onmouseover="this.style.color='var(--coral)';this.style.borderColor='var(--coral-mid)'"
        onmouseout="this.style.color='var(--text-3)';this.style.borderColor='var(--border)'"
      >
        ← All work
      </a>
    </nav>

    <!-- ①  Executive Summary ────────────────────────────── -->
    <CaseStudyHero
      title={d.title}
      description={d.description}
      cover={d.cover}
      problem={d.problem}
      result={d.result}
      resultLabel={d.resultLabel}
      resultContext={d.resultContext}
      tags={d.tags}
      featured={d.featured}
    />

    <!-- ②  Context & Scope ──────────────────────────────── -->
    <CaseStudyMeta
      role={d.role}
      timeline={d.timeline}
      team={d.team}
      date={d.date}
      holder={d.holder}
      holderValue={d.holderValue}
      url={d.url}
      repo={d.repo}
    />

    <!-- ③  The Big Reveal ───────────────────────────────── -->
    <BigReveal
      reveal={d.reveal}
      revealCaption={d.revealCaption}
      revealGallery={d.revealGallery}
      title={d.title}
    />

    <!-- ──────────── Divider ────────────────────────────── -->
    <hr style="border:none;border-top:1px solid var(--border);margin:0 0 3.5rem;" />

    <!-- ④  Deep Dives (MDX prose) ──────────────────────── -->
    <DeepDives>
      <Content />
    </DeepDives>

    <!-- ──────────── Divider ────────────────────────────── -->
    <hr style="border:none;border-top:1px solid var(--border);margin:0 0 3.5rem;" />

    <!-- ⑤  Impact ──────────────────────────────────────── -->
    {d.metrics && d.metrics.length > 0 && (
      <ImpactGrid metrics={d.metrics} />
    )}

    <!-- ⑥  Reflection ──────────────────────────────────── -->
    <ReflectionBlock reflection={d.reflection} />

    <!-- ── Footer nav ───────────────────────────────────── -->
    <div style="
      margin-top:3rem;
      padding-top:2rem;
      border-top:1px solid var(--border);
      display:flex;
      align-items:center;
      justify-content:space-between;
      flex-wrap:wrap;
      gap:1rem;
    ">
      <a
        href="/projects"
        style="
          display:inline-flex;align-items:center;gap:0.375rem;
          font-size:0.85rem;font-weight:700;
          color:var(--coral);text-decoration:none;
        "
      >
        ← Back to all work
      </a>

      {d.url && (
        <a href={d.url} target="_blank" rel="noopener noreferrer"
          class="btn-coral" style="font-size:0.82rem;padding:0.5rem 1.25rem;">
          View live project ↗
        </a>
      )}
    </div>
  </article>
</BaseLayout>
