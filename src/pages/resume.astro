---
import BaseLayout from "../layouts/BaseLayout.astro";

const bold = (str: string) =>
  str.replace(/\*\*(.+?)\*\*/g, "<strong style=\"font-weight:600;color:var(--text);\">$1</strong>");

const experience = [
  {
    company: "Hiya",
    url: "https://hiya.com",
    role: "Senior Product Designer",
    period: "2025 – Present",
    highlights: [
      "Contributing to spam blocking solutions, stay tuned",
    ],
  },
  {
    company: "Eightpoint",
    url: "https://eightpoint.io",
    role: "Lead Product Designer",
    period: "2023 – 2025",
    highlights: [
      "Spearheaded the end-to-end product design and strategy for ToC utility apps. Established a growth design pattern across the suite, resulting in increased design efficiency, leading to a **22% increase in start trial rate** and a **15% boost in P1 retention rate**, ultimately improving user satisfaction and daily revenue.",
      "Designed and implemented monetization and retention strategies for the browser product, resulting in a **27% increase in DAU to 1.5M** and driving a **29% revenue growth** within 6 months.",
      "Actively advocated for enhancing design maturity across the organization by holding 10+ company-wide design workshops and regular co-design sessions. Assisted the design manager in team building and mentoring 2 junior designers.",
      "Crafted a comprehensive global design system **from 0 to 1** to ensure cohesive user experiences across iOS and Android.",
    ],
  },
  {
    company: "Variflight",
    url: "https://www.variflight.com",
    role: "Product Designer",
    period: "2021 – 2021",
    highlights: [
      "Revamped the alternative travel plans recommendation for flight delay or cancellation. Raised the conversion rate from the recommendation page to the ticket booking page by 23% to 2%.",
      "Conducted qualitative and quantitative research on 300+ target users regarding flight delays. Initiated the “delay - no worries” campaign based on research insights, increasing the number of daily flight ticket bookings by 15% to 3000.",
    ],
  },
  {
    company: "Chaoyouai Tech, Mint Reading",
    url: "https://reading.baicizhan.com/",
    role: "Product Designer",
    period: "2020 – 2021",
    highlights: [
      "Customized Mint Reading new membership service system, performed A/B Testing on design decisions with 1000+ customers, and improved membership profit rate from 39% to 52%.",
      "Revised Mint Reading payment user flow. Doubled the conversion rate of new users and increased the repurchase rate of old users from 5% to 7%.",
    ],
  },
];

const skills = [
  { area: "Design & Prototyping", items: ["Figma", "System Building", "Prototyping", "Motion design", "Visual design"] },
  { area: "Research", items: ["User interviews", "Usability testing", "Card sorting", "Journey mapping"] },
  { area: "Systems", items: ["Design tokens", "Component libraries", "Brand identity", "Guidelines"] },
  { area: "Delivery", items: ["Spec & handoff", "Design QA", "A/B testing", "Cross-functional"] },
];

const education = [
  { institution: "University of Washington", degree: "MS Human Computer Interaction", year: "2021-2022" },
  { institution: "City University of Hong Kong", degree: "BE Electrical Engineering", year: "2016-2020" },
];
---

<BaseLayout title="Résumé — Portfolio" description="Experience, skills, and education.">
  <div style="max-width:52rem;margin:0 auto;padding:4rem 1.5rem 7rem;">

    <!-- Header -->
    <header style="margin-bottom:3rem;">
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
        <div style="width:8px;height:8px;border-radius:9999px;background:var(--coral);"></div>
        <span style="font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--coral);">Résumé</span>
      </div>
      <h1 style="
        font-family: 'Instrument Serif', Georgia, serif;
        font-style: italic;
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 400;
        letter-spacing: -0.03em;
        line-height: 1.08;
        color: var(--text);
        margin-bottom: 1rem;
      ">Jingzhi Xu</h1>
      <p style="font-size:1rem;font-weight:300;line-height:1.7;color:var(--text-2);max-width:42ch;">
        Product designer with 5+ years contributing to business growth and crafting digital experiences — from research to high-fidelity, and from 0→1 products to mature design systems.
      </p>
      <div style="margin-top:1.25rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
        <a href="https://drive.google.com/file/d/16wSS9kagtcIoCJcJaiEOJssaSMA7Cxi0/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="btn-coral" style="font-size:0.82rem;padding:0.5rem 1.25rem;">
          View PDF ↗
        </a>
        <a href="/projects" class="btn-outline" style="font-size:0.82rem;padding:0.5rem 1.25rem;">
          View case studies →
        </a>
      </div>
    </header>

    <hr style="border:none;border-top:1px solid var(--border);margin:0 0 3rem;" />

    <!-- Experience -->
    <section style="margin-bottom:3.5rem;">
      <h2 style="
        font-family: var(--font-sans);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--coral);
        margin-bottom: 1.75rem;
      ">Experience</h2>

      <div style="display:flex;flex-direction:column;gap:2.5rem;">
        {experience.map(({ company, url, role, period, highlights }) => (
          <div style="display:grid;grid-template-columns:1fr;gap:0.875rem;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
              <div>
                <p style="
                  font-family: 'Instrument Serif', Georgia, serif;
                  font-style: italic;
                  font-size: 1.2rem;
                  font-weight: 400;
                  letter-spacing: -0.02em;
                  color: var(--text);
                  margin-bottom: 0.2rem;
                ">{role}</p>
                {url ? (
                  <a href={url} target="_blank" rel="noopener noreferrer" style="
                    font-size:0.82rem;font-weight:600;color:var(--text-2);
                    text-decoration:none;display:inline-flex;align-items:center;gap:0.25rem;
                    transition:color 0.2s;
                  "
                    onmouseover="this.style.color='var(--coral)'"
                    onmouseout="this.style.color='var(--text-2)'"
                  >{company} <span style="font-size:0.7rem;opacity:0.6;">↗</span></a>
                ) : (
                  <p style="font-size:0.82rem;font-weight:600;color:var(--text-2);">{company}</p>
                )}
              </div>
              <span style="
                font-size: 0.72rem;
                font-weight: 600;
                letter-spacing: 0.04em;
                color: var(--tag-text);
                background: var(--tag-bg);
                padding: 0.2rem 0.65rem;
                border-radius: 9999px;
                white-space: nowrap;
                align-self: flex-start;
              ">{period}</span>
            </div>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
              {highlights.map(item => (
                <li style="display:flex;gap:0.75rem;font-size:0.875rem;font-weight:300;line-height:1.65;color:var(--text-2);">
                  <span style="color:var(--coral);flex-shrink:0;margin-top:0.05em;">→</span>
                  <span set:html={bold(item)} />
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <hr style="border:none;border-top:1px solid var(--border);margin:0 0 3rem;" />

    <!-- Skills & Tools -->
    <section style="margin-bottom:3.5rem;">
      <h2 style="
        font-family: var(--font-sans);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--coral);
        margin-bottom: 1.75rem;
      ">Skills & Tools</h2>

      <!-- Skills grid -->
      <div style="display:grid;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:1.5rem;overflow:hidden;grid-template-columns:repeat(auto-fill,minmax(min(100%,11rem),1fr));margin-bottom:1.25rem;">
        {skills.map(({ area, items }) => (
          <div style="background:var(--card);padding:1.25rem 1.5rem;">
            <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--coral);margin-bottom:0.75rem;">{area}</p>
            <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.375rem;">
              {items.map(s => (
                <li style="font-size:0.82rem;font-weight:300;color:var(--text-2);">{s}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Tools chips -->
      <div style="
        border: 1px solid var(--border);
        border-radius: 1.5rem;
        padding: 1.25rem 1.5rem;
        background: var(--card);
      ">
        <p style="font-size:0.65rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--coral);margin-bottom:1rem;">Tools</p>
        <div style="display:flex;flex-wrap:wrap;gap:0.625rem;">
          {[
            { name: "Figma",   freq: "Daily" },
            { name: "Claude Code",  freq: "Building" },
            { name: "Notion",  freq: "Thinking" },
            { name: "Rive",  freq: "Motion" },
            { name: "Cursor",  freq: "Tinkering" },
          ].map(({ name, freq }) => (
            <div style="
              display: inline-flex;
              align-items: center;
              gap: 0.5rem;
              background: var(--bg-alt);
              border: 1px solid var(--border);
              border-radius: 0.875rem;
              padding: 0.5rem 0.875rem;
            ">
              <span style="font-size:0.82rem;font-weight:600;color:var(--text);">{name}</span>
              <span style="
                font-size: 0.65rem;
                font-weight: 500;
                color: var(--text-3);
                background: var(--tag-bg);
                padding: 0.1rem 0.45rem;
                border-radius: 9999px;
                letter-spacing: 0.03em;
              ">{freq}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr style="border:none;border-top:1px solid var(--border);margin:0 0 3rem;" />

    <!-- Education -->
    <section>
      <h2 style="
        font-family: var(--font-sans);
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--coral);
        margin-bottom: 1.75rem;
      ">Education</h2>

      <div style="display:flex;flex-direction:column;gap:1.25rem;">
        {education.map(({ institution, degree, year }) => (
          <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
            <div>
              <p style="
                font-family: 'Instrument Serif', Georgia, serif;
                font-style: italic;
                font-size: 1.05rem;
                font-weight: 400;
                color: var(--text);
                margin-bottom: 0.15rem;
              ">{degree}</p>
              <p style="font-size:0.82rem;font-weight:400;color:var(--text-2);">{institution}</p>
            </div>
            <span style="
              font-size: 0.72rem;
              font-weight: 600;
              color: var(--tag-text);
              background: var(--tag-bg);
              padding: 0.2rem 0.65rem;
              border-radius: 9999px;
            ">{year}</span>
          </div>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
